import argparse
import os
import re
import sys

__version__ = "0.2.0"

# exit codes
EX_OK = 0
EX_USAGE = 2
EX_NO_TARGET = 3
EX_NOT_ROOT = 4
EX_INJECT_FAILED = 5
EX_BAD_CONDITION = 6


def eprint(*a):
    print(*a, file=sys.stderr)


def sanitize_condition(cond: str) -> str:
    """Reject control characters. A goal condition is a single input line; any
    C0 control (CR/LF/ESC/TAB/...) or DEL would let the string smuggle a second
    keystroke/slash-command into the session. Fail closed."""
    for ch in cond:
        o = ord(ch)
        if o < 0x20 or o == 0x7F:
            raise ValueError(
                "condition contains a control character (0x%02x); refusing to "
                "inject. Goal text must be a single printable line." % o
            )
    if not cond.strip():
        raise ValueError("empty condition")
    return cond


def _read(path):
    try:
        with open(path, "rb") as f:
            return f.read()
    except OSError:
        return b""


def _proc_comm(pid):
    return _read("/proc/%d/comm" % pid).decode("utf-8", "replace").strip()


def _proc_cmdline(pid):
    return _read("/proc/%d/cmdline" % pid).replace(b"\x00", b" ").decode("utf-8", "replace").strip()


def _proc_ppid(pid):
    data = _read("/proc/%d/stat" % pid)
    if not data:
        return None
    # field 4 is ppid; comm (field 2) may contain spaces/parens, so split after ')'
    try:
        rest = data[data.rindex(b")") + 2:].split()
        return int(rest[1])
    except (ValueError, IndexError):
        return None


def _fd_target(pid, fd):
    try:
        return os.readlink("/proc/%d/fd/%d" % (pid, fd))
    except OSError:
        return ""


def _controlling_pts(pid):
    """Return the process's CONTROLLING terminal as /dev/pts/N, or "" if it has
    none. Reads tty_nr (field 7) from /proc/<pid>/stat; 0 means no controlling
    tty. This is what separates a live interactive session (whose pts is its
    controlling terminal) from a daemon-managed background session that merely
    holds a pts fd but reads its input over a socket."""
    data = _read("/proc/%d/stat" % pid)
    if not data:
        return ""
    try:
        rest = data[data.rindex(b")") + 2:].split()
        tty_nr = int(rest[4])
    except (ValueError, IndexError):
        return ""
    if tty_nr == 0:
        return ""
    major = (tty_nr >> 8) & 0xFFF
    minor = (tty_nr & 0xFF) | ((tty_nr >> 12) & 0xFFF00)
    if major != 136:  # 136 = UNIX98 pts
        return ""
    return "/dev/pts/%d" % minor


def is_claude(comm, cmdline):
    """Identify a Claude Code process across install shapes (native `claude.exe`
    binary or node `cli.js`). Kept strict on purpose: the safety model relies on
    only ever targeting a real Claude Code ancestor."""
    if comm.strip().lower() in ("claude", "claude.exe"):
        return True
    # node install: argv contains the package path
    return "@anthropic-ai/claude-code/" in cmdline.lower()


def find_claude_pts(start_pid=None):
    """Controlling pts of our NEAREST Claude Code ancestor — (pts_path, pid) if
    that ancestor is a live interactive session on a pts, else (None, None).

    We classify ONLY the nearest Claude ancestor and never reach past it. That
    matters for a daemon/background session launched from an interactive Claude:
    the nearest Claude has no controlling tty, and scanning further up would find
    the *foreground parent* session's pts and inject into the wrong session.

    Requirements for the nearest Claude ancestor:
      * its stdin and stdout are the same pts;
      * that pts is its CONTROLLING terminal (rejects daemon `/bg` sessions,
        which hold a pts fd but read input over a socket)."""
    cpid = find_claude_ancestor(start_pid)
    if cpid is None:
        return None, None
    fd0 = _fd_target(cpid, 0)
    fd1 = _fd_target(cpid, 1)
    if fd0.startswith("/dev/pts/") and fd0 == fd1 and fd0 == _controlling_pts(cpid):
        return fd0, cpid
    return None, None


def find_claude_ancestor(start_pid=None):
    """First Claude Code process in our ancestry, or None. Unlike find_claude_pts
    this does not require a controlling pts — used to locate a daemon-managed
    session so we can read back its session id."""
    pid = start_pid if start_pid is not None else os.getppid()
    seen = 0
    while pid and pid > 1 and seen < 40:
        seen += 1
        if is_claude(_proc_comm(pid), _proc_cmdline(pid)):
            return pid
        nxt = _proc_ppid(pid)
        if nxt == pid:
            break
        pid = nxt
    return None


def _rv_session_id(inodes, unix_lines):
    """Pure: given a set of socket inode strings and /proc/net/unix lines, return
    the session id of the process's own rendezvous socket. Fail closed: we accept
    ONLY a LISTENING `.../rv/<id>.sock` the process owns, and only when there is
    exactly one such id. Zero (headless, or only client rv fds) or more than one
    (ambiguous) -> None. A connected-but-not-listening rv fd never counts."""
    ids = set()
    for line in unix_lines:
        parts = line.split()
        if len(parts) < 8:
            continue
        flags, inode, path = parts[3], parts[6], parts[7]
        if inode not in inodes or "/rv/" not in path or not path.endswith(".sock"):
            continue
        base = path.rsplit("/", 1)[1][:-len(".sock")]
        if not re.fullmatch(r"[0-9a-f]{6,}", base):
            continue
        try:
            listening = bool(int(flags, 16) & 0x10000)  # SO_ACCEPTCON
        except ValueError:
            listening = False
        if listening:
            ids.add(base)
    return next(iter(ids)) if len(ids) == 1 else None


def find_session_id(claude_pid):
    """Read the daemon session id off the Claude process's own listening
    rendezvous socket. The process LISTENs on `.../rv/<id>.sock`; we map its
    socket fds to paths via /proc/net/unix and pull <id> out. Returns the id
    string or None."""
    inodes = set()
    try:
        fds = os.listdir("/proc/%d/fd" % claude_pid)
    except OSError:
        return None
    for fd in fds:
        try:
            t = os.readlink("/proc/%d/fd/%s" % (claude_pid, fd))
        except OSError:
            continue
        m = re.match(r"socket:\[(\d+)\]$", t)
        if m:
            inodes.add(m.group(1))
    if not inodes:
        return None
    return _rv_session_id(inodes, _read("/proc/net/unix").decode("utf-8", "replace").splitlines())


def tiocsti_inject(pts_path, line):
    import fcntl
    import termios

    fd = os.open(pts_path, os.O_WRONLY | os.O_NOCTTY)
    try:
        for ch in line.encode("utf-8"):
            fcntl.ioctl(fd, termios.TIOCSTI, bytes([ch]))
    finally:
        os.close(fd)


def tmux_pane_tty(pane):
    import subprocess

    try:
        out = subprocess.run(
            ["tmux", "display-message", "-p", "-t", pane, "#{pane_tty}"],
            capture_output=True, text=True, check=True)
        return out.stdout.strip()
    except Exception:
        return ""


def tmux_inject(pane, line):
    import subprocess

    # send the text, then a separate Enter, so the payload is never re-parsed
    subprocess.run(["tmux", "send-keys", "-t", pane, "-l", line], check=True)
    subprocess.run(["tmux", "send-keys", "-t", pane, "Enter"], check=True)


def attach_inject(session_id, line, connect_wait=6.0, settle=3.0):
    """Deliver `line` to a daemon-managed session by running `claude attach <id>`
    in a private pty (the official client speaks the rv-socket protocol), typing
    the line + Enter, then detaching. The target session keeps running. Returns
    None on success, or an error string."""
    import pty
    import select
    import shutil
    import signal
    import time

    if shutil.which("claude") is None:
        return "`claude` not found on PATH (needed to attach)"
    try:
        pid, master = pty.fork()
    except OSError as e:
        return "pty.fork failed: %s" % e
    if pid == 0:
        try:
            os.setsid()  # own session/process group so we can reap the whole tree
        except OSError:
            pass
        os.environ["TERM"] = "xterm-256color"
        os.execvp("claude", ["claude", "attach", session_id])
        os._exit(127)

    def child_exit():
        """Return the child's exit status if it has exited, else None."""
        try:
            wpid, status = os.waitpid(pid, os.WNOHANG)
        except ChildProcessError:
            return 0
        return status if wpid == pid else None

    def drain(seconds):
        """Read+discard output for up to `seconds`; stop early if the child exits.
        Returns True if the child is still alive, False if it exited."""
        end = time.time() + seconds
        while time.time() < end:
            if child_exit() is not None:
                return False
            r, _, _ = select.select([master], [], [], 0.3)
            if r:
                try:
                    if not os.read(master, 65536):
                        break
                except OSError:
                    break
        return child_exit() is None

    def detach():
        try:
            os.close(master)
        except OSError:
            pass
        for sig in (signal.SIGTERM, signal.SIGKILL):
            if child_exit() is not None:
                break
            try:
                os.killpg(pid, sig)  # pid == pgid because the child called setsid
            except OSError:
                try:
                    os.kill(pid, sig)
                except OSError:
                    pass
            time.sleep(0.3)
        try:
            os.waitpid(pid, os.WNOHANG)
        except OSError:
            pass

    alive = drain(connect_wait)  # let the attach client connect + render
    if not alive:
        detach()
        return "`claude attach %s` exited before we could inject (bad/unknown id?)" % session_id
    try:
        for ch in line.encode("utf-8"):
            os.write(master, bytes([ch]))
            time.sleep(0.004)
        time.sleep(0.4)
        os.write(master, b"\r")
    except OSError as e:
        detach()
        return "writing to attach client failed: %s" % e
    drain(settle)
    detach()
    return None


def in_tmux():
    return bool(os.environ.get("TMUX")) and bool(os.environ.get("TMUX_PANE"))


def build_line(args):
    if args.clear:
        return "/goal clear"
    cond = sanitize_condition(args.condition)
    return "/goal " + cond


def main(argv=None):
    p = argparse.ArgumentParser(
        prog="claude-self-goal",
        description="Let a running Claude Code session set its own native /goal.",
    )
    p.add_argument("condition", nargs="?", help="the goal condition to keep working until it holds")
    p.add_argument("--clear", action="store_true", help="clear the current goal (inject '/goal clear')")
    p.add_argument("--dry-run", action="store_true", help="show the chosen method + target and the exact line, but do not inject")
    p.add_argument("--method", choices=["auto", "tmux", "tiocsti", "attach"], default="auto",
                   help="delivery method (default: auto — picks tmux / tiocsti / attach "
                        "by session type)")
    p.add_argument("--session", metavar="ID",
                   help="target a specific daemon-managed session by id (implies --method "
                        "attach; use it to set a goal on another background session)")
    p.add_argument("--unsafe-pts", metavar="/dev/pts/N",
                   help="inject into an explicit pts instead of discovering it (DANGEROUS)")
    p.add_argument("--i-understand-this-can-inject-keystrokes", dest="ack_unsafe",
                   action="store_true", help="required acknowledgement for --unsafe-pts")
    p.add_argument("--version", action="version", version="claude-self-goal " + __version__)
    args = p.parse_args(argv)

    # Safety valve: CLAUDE_SELF_GOAL_DRY_RUN=1 forces dry-run, so nothing is ever
    # injected. Test suites set this so a buggy test can never fire a real /goal
    # into the session running the tests.
    if os.environ.get("CLAUDE_SELF_GOAL_DRY_RUN") == "1":
        args.dry_run = True

    if not args.clear and not args.condition:
        p.error("a goal condition is required (or use --clear)")
    if args.clear and args.condition:
        p.error("--clear takes no condition")
    if args.session:
        if not re.fullmatch(r"[0-9a-f-]{6,}", args.session):
            p.error("--session id must look like a session id (hex, e.g. 994f658d)")
        if args.method not in ("auto", "attach"):
            p.error("--session implies --method attach; drop --method or set it to attach")
    # --unsafe-pts is a tiocsti-only override; validate it here (before any
    # injection path) and force the tiocsti method, so it can never be
    # auto-routed to the attach path.
    if args.unsafe_pts:
        if args.session:
            p.error("--unsafe-pts and --session are mutually exclusive")
        if args.method not in ("auto", "tiocsti"):
            p.error("--unsafe-pts implies --method tiocsti")
        if not args.ack_unsafe:
            p.error("--unsafe-pts requires --i-understand-this-can-inject-keystrokes")
        if not re.fullmatch(r"/dev/pts/[0-9]+", args.unsafe_pts):
            p.error("--unsafe-pts must be a /dev/pts/N path")
        args.method = "tiocsti"

    try:
        line = build_line(args)
    except ValueError as e:
        eprint("claude-self-goal: " + str(e))
        return EX_BAD_CONDITION

    # ---- method selection ----------------------------------------------------
    method = args.method
    session_id = args.session
    if method == "auto":
        if session_id:
            method = "attach"
        else:
            # Classify ONLY the nearest Claude ancestor.
            pts, _ = find_claude_pts()
            if pts is not None:
                # interactive pts session. Prefer tmux only if we're actually in
                # tmux AND this session's pts is that pane's tty (a /bg session
                # can inherit TMUX env without being an interactive tmux pane).
                pane = os.environ.get("TMUX_PANE")
                if in_tmux() and pane and tmux_pane_tty(pane) == pts:
                    method = "tmux"
                else:
                    method = "tiocsti"
            else:
                # No controlling-tty pts on the nearest Claude. If it's a daemon
                # session we can read its id off its rv socket -> attach. Else
                # headless (piped stdin) -> refuse.
                cpid = find_claude_ancestor()
                sid = find_session_id(cpid) if cpid else None
                if sid:
                    method, session_id = "attach", sid
                else:
                    eprint("claude-self-goal: no way to deliver a /goal to this session.")
                    eprint("  The nearest Claude Code ancestor has neither a controlling pts nor")
                    eprint("  a daemon rv socket. A headless `claude -p` session (piped stdin)")
                    eprint("  cannot take an interactive /goal. Run this from an interactive")
                    eprint("  terminal, a tmux session, or a `/bg` session — or pass --session <id>.")
                    return EX_NO_TARGET

    if method == "attach":
        if not session_id:
            cpid = find_claude_ancestor()
            session_id = find_session_id(cpid) if cpid else None
            if not session_id:
                eprint("claude-self-goal: --method attach but no session id found.")
                eprint("  Could not read this session's id from its rv socket; pass --session <id>.")
                return EX_NO_TARGET
        if args.dry_run:
            print("method=attach session=%s line=%r" % (session_id, line))
            return EX_OK
        err = attach_inject(session_id, line)
        if err:
            eprint("claude-self-goal: attach injection failed: " + err)
            return EX_INJECT_FAILED
        print("claude-self-goal: sent %r to session %s via claude attach" % (line, session_id))
        return EX_OK

    if method == "tmux":
        pane = os.environ.get("TMUX_PANE")
        if not pane:
            eprint("claude-self-goal: --method tmux but not inside tmux (TMUX_PANE unset)")
            return EX_NO_TARGET
        # fail-closed: the pane we send to must be the tty of the Claude Code
        # process we descend from. This defends against a stale/forged TMUX_PANE
        # pointing at some other pane.
        pts, cpid = find_claude_pts()
        if pts is None:
            eprint("claude-self-goal: refusing — no Claude Code ancestor with a pts found")
            return EX_NO_TARGET
        pane_tty = tmux_pane_tty(pane)
        if pane_tty != pts:
            eprint("claude-self-goal: refusing — tmux pane %s (tty %s) is not this Claude "
                   "session's terminal (%s)" % (pane, pane_tty or "?", pts))
            return EX_NO_TARGET
        if args.dry_run:
            print("method=tmux pane=%s tty=%s line=%r" % (pane, pane_tty, line))
            return EX_OK
        try:
            tmux_inject(pane, line)
        except Exception as e:
            eprint("claude-self-goal: tmux send-keys failed: " + str(e))
            return EX_INJECT_FAILED
        print("claude-self-goal: sent %r to tmux pane %s (%s)" % (line, pane, pane_tty))
        return EX_OK

    # tiocsti path (args.unsafe_pts already validated up-front)
    if args.unsafe_pts:
        pts = args.unsafe_pts
    else:
        pts, _ = find_claude_pts()
        if pts is None:
            eprint("claude-self-goal: no live interactive Claude Code pts found in this ancestry.")
            eprint("  The session either is headless (piped stdin / `claude -p`), or is a")
            eprint("  daemon-managed background session (`/bg`) whose input arrives over a")
            eprint("  socket rather than a controlling terminal. In both cases there is no pts")
            eprint("  to inject a /goal into. Run this from an interactive terminal or a tmux")
            eprint("  session, or pass --unsafe-pts explicitly if you truly know the target.")
            return EX_NO_TARGET

    if args.dry_run:
        print("method=tiocsti pts=%s line=%r (needs a context that permits TIOCSTI)" % (pts, line))
        return EX_OK

    try:
        tiocsti_inject(pts, line + "\r")
    except OSError as e:
        # TIOCSTI depends on privilege AND kernel/container policy — diagnose both.
        if os.geteuid() != 0:
            eprint("claude-self-goal: TIOCSTI failed on %s (%s)." % (pts, e))
            eprint("  It needs root or CAP_SYS_ADMIN. Re-run as root, or use tmux (no root).")
            return EX_NOT_ROOT
        eprint("claude-self-goal: TIOCSTI failed on %s (%s)." % (pts, e))
        eprint("  Even as root this can be blocked by kernel config (legacy_tiocsti compiled")
        eprint("  out), a seccomp filter, or a container/user-namespace policy.")
        return EX_INJECT_FAILED
    print("claude-self-goal: injected %r into %s" % (line, pts))
    return EX_OK


if __name__ == "__main__":
    sys.exit(main())
